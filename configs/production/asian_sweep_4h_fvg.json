      "Swept_AL_Into_FVG",
      "Swept_AH_Into_FVG",
      "1h_Bullish_Flip",
      "1h_Bearish_Flip",
      "UA_Hour"
    ]
  },
  "parameters": {},
  "logic": {
    "filters": [
      {
        "comment": "Trade only AFTER the Asian Session is locked",
        "feature": "UA_Hour",
        "operator": ">=",
        "value": 9
      },
      {
        "comment": "Stop taking sweeps late in the US session",
        "feature": "UA_Hour",
        "operator": "<=",
        "value": 18
      }
    ],
    "entry_rules": {
      "long_trigger": [
        {
          "feature": "Swept_AL_Into_FVG",
          "operator": "==",
          "value": 1
        },
        {
          "feature": "1h_Bullish_Flip",
          "operator": "==",
          "value": 1
        }
      ],
      "short_trigger": [
        {
          "feature": "Swept_AH_Into_FVG",
          "operator": "==",
          "value": 1
        },
        {
          "feature": "1h_Bearish_Flip",
          "operator": "==",
          "value": 1
        }
      ]
    },
    "execution_rules": {
      "mode": "risk_reward",
      "risk_reward_ratio": 2.0,
      "sl_atr_multiplier": 1.0,
      "max_hold_bars": null,
      "max_trades_per_day": 1,
      "allow_resweep": false
    }
  }
