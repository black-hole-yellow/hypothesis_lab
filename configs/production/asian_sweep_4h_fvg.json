{
  "metadata": {
    "hypothesis_id": "H_006_ASIAN_SWEEP_FVG",
    "name": "Asian Killzone Sweep to 4H FVG",
    "author": "Quant_Lab_Alpha",
    "rationale": "Identifies when price sweeps the Asian High/Low to grab liquidity, perfectly tapping a resting 4H FVG before printing an immediate order flow reversal."
  },
  "universe": {
    "instruments": [
      "GBPUSD"
    ],
    "resolution": "1h",
    "timezone": "UTC"
  },
  "data_dependencies": {
