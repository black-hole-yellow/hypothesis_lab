{
  "metadata": {
    "hypothesis_id": "H_005_LDN_1D_FVG_FRACTAL",
    "name": "London Fractal in 1D FVG Reversal",
    "author": "Quant_Lab_Alpha",
    "rationale": "Uses the new universal parser to detect when a confirmed London-session fractal forms inside a 1D Fair Value Gap, expecting an intraday reversal."
  },
  "universe": {
    "instruments": ["GBPUSD"],
    "resolution": "1h",
    "timezone": "UTC"
  },
  "data_dependencies": {
    "required_features": [
      "Confirmed_Fractal_High",
      "Confirmed_Fractal_Low",
      "FVG_1D_Top",
      "FVG_1D_Bottom",
      "UA_Hour"
    ]
  },
  "parameters": {},
  "logic": {
    "filters": [
      {
        "feature": "UA_Hour",
        "operator": ">=",
        "value": 10
      },
      {
        "feature": "UA_Hour",
        "operator": "<=",
        "value": 18
      }
    ],
    "entry_rules": {
      "long_trigger": [
        {
          "comment": "Is there a confirmed Fractal Low?",
          "feature": "Confirmed_Fractal_Low",
          "operator": "==",
          "value": 1
        },
        {
          "comment": "Is the 1D FVG Bullish?",
          "feature": "FVG_1D_Type",
          "operator": "==",
          "value": "BULL"
        },
        {
          "comment": "Is the Fractal Low above the FVG Bottom?",
          "feature": "Confirmed_Fractal_Low_Price",
          "operator": ">=",
          "target_column": "FVG_1D_Bottom"
        },
        {
          "comment": "Is the Fractal Low below the FVG Top?",
          "feature": "Confirmed_Fractal_Low_Price",
          "operator": "<=",
          "target_column": "FVG_1D_Top"
        }
      ],
      "short_trigger": [
        {
          "comment": "Is there a confirmed Fractal High?",
          "feature": "Confirmed_Fractal_High",
          "operator": "==",
          "value": 1
        },
        {
          "comment": "Is the 1D FVG Bearish?",
          "feature": "FVG_1D_Type",
          "operator": "==",
          "value": "BEAR"
        },
        {
          "comment": "Is the Fractal High above the FVG Bottom?",
          "feature": "Confirmed_Fractal_High_Price",
          "operator": ">=",
          "target_column": "FVG_1D_Bottom"
        },
        {
          "comment": "Is the Fractal High below the FVG Top?",
          "feature": "Confirmed_Fractal_High_Price",
          "operator": "<=",
          "target_column": "FVG_1D_Top"
        }
      ]
    },
    "exit_rules": {
      "max_hold_time_hours": 12
    }
  }
}